// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("postgresql://bhabii_game_db_user:xjJVSgN0jOK9uD3RHAkAU8OGW9byxTwh@dpg-d8oib4cm0tmc73cpt19g-a/bhabii_game_db")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  avatar    String?
  coins     Int      @default(1000)
  xp        Int      @default(0)
  wins      Int      @default(0)
  losses    Int      @default(0)
  rank      Int      @default(1000) // ELO Rating
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  sentFriends     Friend[]        @relation("SentFriends")
  receivedFriends Friend[]        @relation("ReceivedFriends")
  chatMessages    ChatMessage[]
  matchesAsWinner MatchPlayer[]   @relation("WinnerRelation")
  matchHistory    MatchPlayer[]   
}

model Friend {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  status     String   @default("PENDING") // PENDING, ACCEPTED, BLOCKED
  createdAt  DateTime @default(now())

  sender   User @relation("SentFriends", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedFriends", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

model Match {
  id        String   @id @default(uuid())
  roomCode  String?
  status    String   @default("COMPLETED") // COMPLETED, ABANDONED
  duration  Int      @default(0) // in seconds
  createdAt DateTime @default(now())

  // Players in this match
  players MatchPlayer[]
}

model MatchPlayer {
  id       String  @id @default(uuid())
  matchId  String
  userId   String
  isWinner Boolean @default(false)
  xpEarned Int     @default(0)
  coinsChange Int  @default(0)
  rankChange  Int  @default(0)

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade, map: "matchplayer_user_fkey")
  User_WinnerRelation User? @relation("WinnerRelation", fields: [userId], references: [id], map: "matchplayer_winner_fkey")
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  username  String
  message   String
  roomCode  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
